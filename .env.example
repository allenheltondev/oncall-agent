# Runtime
NODE_ENV=development
LOG_LEVEL=info

# Momento Topics
MOMENTO_API_KEY=
MOMENTO_CACHE_NAME=oncall-agent
MOMENTO_TOPIC_NAME=incidents

# Teleport
TELEPORT_PROXY=
TELEPORT_CLUSTER=
TELEPORT_AUDIENCE=oncall-agent
TELEPORT_AWS_ROLE=TeleportReadOnlyAccess
TELEPORT_AWS_APP_NAME=ReadOnly-aws-ra-integrationTELEPORT_MOCK_IDENTITY=true
# TELEPORT_ISSUER_COMMAND_AWS=./scripts/teleport-aws-issuer
# TELEPORT_ISSUER_COMMAND_GITHUB=./scripts/teleport-github-issuer

# AWS
AWS_REGION=us-east-1

# GitHub
GITHUB_OWNER=allenheltondev
GITHUB_REPO=oncall-agent
GITHUB_BASE_BRANCH=main

# GitHub Authentication (choose one)
# Option 1: Personal Access Token (easiest)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2: GitHub App (recommended for production)
# GITHUB_APP_ID=123456
# GITHUB_APP_INSTALLATION_ID=789012
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
# GITHUB_APP_PRIVATE_KEY_FILE=./path/to/private-key.pem
# Slack
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#oncall-agent

# LLM Provider (codex or bedrock)
# LLM_PROVIDER=codex

# Codex/OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.3-codex
# OPENAI_BASE_URL=https://api.openai.com/v1

# Amazon Bedrock
# LLM_PROVIDER=bedrock
# LLM_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0
# BEDROCK_REGION=us-east-1

# Remediation execution
REMEDIATION_EXECUTE=false
REMEDIATION_OPEN_PR=false
REMEDIATION_ALLOW_DIRTY_WORKTREE=false

# Storage mode
STORAGE_MODE=json
SQLITE_PATH=data/oncall-agent.db
